@model IReadOnlyCollection<SGRH.Web.Models.FloorViewModel>

@{
    ViewData["Title"] = "Floors";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 mb-1">Floors</h1>
        <p class="text-muted mb-0">Gestion de pisos consumiendo la API.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nuevo floor</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Numero</th>
                        <th>Descripcion</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No hay floors disponibles.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FloorId</td>
                                <td>@item.FloorNumber</td>
                                <td>@item.Description</td>
                                <td><span class="badge bg-secondary">@item.Status</span></td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.FloorId" class="btn btn-sm btn-outline-primary">Editar</a>
                                    <a asp-action="Delete" asp-route-id="@item.FloorId" class="btn btn-sm btn-outline-danger">Eliminar</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
